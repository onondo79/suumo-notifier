# ===== これは「見本」ファイルです =====
#
# このファイルをコピーして、ファイル名を「.env」に変えて使います。
# （.env はパスワードを書くファイルなので、Gitには絶対に上げません＝.gitignore済み）
#
# 中身は「名前=値」の形で書きます。= の前後にスペースを入れないでください。

# あなたのGmailアドレス
GMAIL_ADDRESS=yourname@gmail.com

# Gmailの「アプリパスワード」（16文字。普段のログインパスワードではありません）
# 取得方法は README.md を見てください。スペースは入れず16文字続けて書きます。
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
